<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Générateur d'Étiquettes A4</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        :root {
            --blue-france: #000091;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* --- PANNEAU DE CONTRÔLE (Masqué à l'impression) --- */
        .controls {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            width: 100%;
            max-width: 600px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
            justify-content: center;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        input {
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            width: 120px;
        }

        button {
            padding: 10px 20px;
            background-color: var(--blue-france);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 18px; /* Alignement avec les inputs */
        }

        button.btn-print {
            background-color: #4CAF50;
        }

        button:hover { opacity: 0.9; }

        /* --- ZONE DE RENDU A4 --- */
        .page-a4 {
            background: white;
            width: 210mm; /* Largeur exacte A4 */
            min-height: 297mm; /* Hauteur A4 minimum */
            padding: 10mm; /* Marges d'impression */
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
            box-sizing: border-box;
            
            /* Grille pour les étiquettes : 3 colonnes */
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-auto-rows: min-content;
            gap: 5mm; /* Espace entre les étiquettes */
        }

        .label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border: 1px dashed #ccc; /* Lignes de découpe */
            padding: 10mm 5mm;
            box-sizing: border-box;
            page-break-inside: avoid; /* Évite de couper une étiquette sur 2 pages */
        }

        .label-text {
            margin-top: 8px;
            font-family: monospace;
            font-size: 14px;
            font-weight: bold;
            color: #333;
        }

        /* --- RÈGLES SPÉCIFIQUES POUR L'IMPRESSION --- */
        @media print {
            body {
                background-color: white;
                margin: 0;
                padding: 0;
            }
            .controls {
                display: none; /* Masque le formulaire à l'impression */
            }
            .page-a4 {
                box-shadow: none;
                margin: 0;
                width: 100%;
                min-height: auto;
            }
            @page {
                size: A4;
                margin: 0; /* Géré par le padding de .page-a4 */
            }
        }
    </style>
</head>
<body>

    <div class="controls">
        <div class="input-group">
            <label for="startNum">Premier numéro :</label>
            <input type="number" id="startNum" value="1" min="0">
        </div>
        <div class="input-group">
            <label for="qty">Quantité :</label>
            <input type="number" id="qty" value="21" min="1">
        </div>
        <button onclick="genererPlanche()">Générer</button>
        <button class="btn-print" onclick="window.print()">Imprimer</button>
    </div>

    <div class="page-a4" id="printArea">
        </div>

    <script>
        function genererPlanche() {
            const startNum = parseInt(document.getElementById('startNum').value, 10);
            const qty = parseInt(document.getElementById('qty').value, 10);
            const printArea = document.getElementById('printArea');
            
            // On vide la zone avant de générer
            printArea.innerHTML = '';

            for (let i = 0; i < qty; i++) {
                // Calcul du numéro courant
                const currentNum = startNum + i;
                
                // Formatage : "MOB-" suivi de 6 chiffres (ex: 000001)
                const formattedText = `MOB-${String(currentNum).padStart(6, '0')}`;

                // Création du conteneur de l'étiquette
                const labelDiv = document.createElement('div');
                labelDiv.className = 'label';

                // Conteneur spécifique pour le QR Code
                const qrContainer = document.createElement('div');
                
                // Élément texte
                const textDiv = document.createElement('div');
                textDiv.className = 'label-text';
                textDiv.innerText = formattedText;

                // Assemblage
                labelDiv.appendChild(qrContainer);
                labelDiv.appendChild(textDiv);
                printArea.appendChild(labelDiv);

                // Génération du QR Code avec la bibliothèque
                new QRCode(qrContainer, {
                    text: formattedText,
                    width: 100,  // Largeur du QR Code en pixels
                    height: 100, // Hauteur du QR Code en pixels
                    colorDark : "#000000",
                    colorLight : "#ffffff",
                    correctLevel : QRCode.CorrectLevel.M // Niveau de correction moyen
                });
            }
        }

        // Générer une planche par défaut au chargement de la page
        window.onload = genererPlanche;
    </script>

</body>
</html>
